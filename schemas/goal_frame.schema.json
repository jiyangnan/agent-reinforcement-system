{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/agent-reinforcement-system/goal_frame.schema.json",
  "title": "GoalFrame",
  "type": "object",
  "required": [
    "goal_id",
    "name",
    "goal",
    "success_criteria",
    "constraints",
    "risk_level",
    "external_side_effects",
    "max_iterations",
    "max_consecutive_failures",
    "owner",
    "created_at"
  ],
  "properties": {
    "goal_id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "goal": { "type": "string", "minLength": 1 },
    "success_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "non_goals": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "external_side_effects": { "type": "boolean" },
    "escalation_points": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "abort_conditions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "max_iterations": { "type": "integer", "minimum": 1 },
    "max_consecutive_failures": { "type": "integer", "minimum": 1 },
    "owner": {
      "type": "string",
      "enum": ["user", "agent"]
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
